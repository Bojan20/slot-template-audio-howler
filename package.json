{
  "name": "slot-template-audio-howler",
  "version": "1.0.0",
  "description": "template for howler audio for slot games",
  "main": "makemyjson.js",
  "scripts": {
    "test": "node makemyjson.js",
    "build-audio": "node scripts/convertAudio.js && node scripts/makeMyJSON.js audio",
    "build-audioSprite": "node scripts/createAudioSprite.js && node scripts/makeMyJSON.js audioSprite",
    "build-multi-audioSprites": "node scripts/createmultipleAudioSprites.js 3 && node scripts/makeMyJSONMultipleSounds.js audioSprite 3",
    "deploy": "node scripts/copyAudio.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/igtinteractive/slot-template-audio-howler.git"
  },
  "keywords": [
    "audio"
  ],
  "author": "jkr",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/igtinteractive/slot-template-audio-howler/issues"
  },
  "homepage": "https://github.com/igtinteractive/slot-template-audio-howler#readme",
  "dependencies": {
    "node-exiftool": "^2.3.0",
    "sox": "^0.1.0",
    "audiosprite": "^0.7.2",
    "ffmpeg-static": "^5.1.0"
  }
}
